# Optional: production API origin (no trailing slash). Leave unset for local dev — Vite proxies /api to localhost:3000.
# VITE_API_BASE_URL=https://your-api.railway.app

# --- Supabase Auth (required for sign-up + 3 free briefs) ---
# Same project as server SUPABASE_URL. Enable Email provider in Supabase Auth settings.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key
