ANTHROPIC_API_KEY=your_key_here

# Optional. When set, job posting URLs are scraped with Firecrawl first; Claude uses that
# markdown only (no web search). Get a key at https://firecrawl.dev
# FIRECRAWL_API_KEY=

# Web search runs on Anthropic’s servers. Your org must allow it in the Claude Console
# (Privacy / tools settings). See: https://docs.anthropic.com/en/docs/agents-and-tools/tool-use/web-search-tool

# Production: set to your deployed React app origin so the API accepts browser requests (CORS).
# Leave unset locally — the server allows Vite dev servers on ports 5173–5174.
# FRONTEND_URL=https://your-app.vercel.app

# --- Google Sheets usage logs (optional) ---
# Create a Google Cloud project, enable "Google Sheets API", create a service account,
# download JSON, and share your spreadsheet with the service account email (Editor).
# Spreadsheet ID = the long id in the sheet URL.
# GOOGLE_SHEETS_SPREADSHEET_ID=
# Tab name for append rows (create a sheet tab with this name):
# GOOGLE_SHEETS_TAB_NAME=logs
#
# For Vercel/serverless (no file reads): paste the entire service account JSON as one line:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
#
# Recommended local auth: path to the service account JSON (no PEM escaping issues).
# Relative paths are resolved from the repo root (same cwd as npm start for the API):
# GOOGLE_APPLICATION_CREDENTIALS=./client/secrets/your-project-abc123.json
# Or an absolute path:
# GOOGLE_APPLICATION_CREDENTIALS=/Users/you/secrets/prepbrief-sa.json
# (alias) GOOGLE_SERVICE_ACCOUNT_KEY_FILE=/absolute/path/to/key.json
#
# Alternative: paste PEM into .env (must include BEGIN/END lines; use \n for newlines):
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
#
# Row order appended (add this header row in row 1 of the tab; columns A–U):
# timestamp_iso | request_id | endpoint | event_type | job_url | company_url |
# client_ip | user_agent | http_status | error_code | error_message |
# anthropic_model | elapsed_ms | input_tokens | output_tokens | web_search_requests |
# response_truncated | response_markdown | resume_attached | resume_chars | resume_parsed_text
